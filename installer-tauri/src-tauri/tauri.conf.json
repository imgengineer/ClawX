{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClawMate Setup",
  "version": "0.2.3",
  "identifier": "app.clawx.setup",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ClawMate Setup",
        "width": 1040,
        "height": 760,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "center": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/payload.zip"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
